{
  "info": {
    "name": "Trendsee API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["users"]
            }
          }
        },
        {
          "name": "Get User Token",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8000/users/1/token",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["users", "1", "token"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PATCH",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["users", "1"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8000/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["users", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Create Post",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Post\",\n  \"text\": \"This is the content of my first post.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/posts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Update Post",
          "request": {
            "method": "PATCH",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"text\": \"Updated content.\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/posts/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["posts", "1"]
            }
          }
        },
        {
          "name": "Delete Post",
          "request": {
            "method": "DELETE",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "http://localhost:8000/posts/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["posts", "1"]
            }
          }
        },
        {
          "name": "Get User Posts",
          "request": {
            "method": "GET",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": {
              "raw": "http://localhost:8000/posts/users/1/posts?limit=10&offset=0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["posts", "users", "1", "posts"],
              "query": [
                {"key": "limit", "value": "10"},
                {"key": "offset", "value": "0"}
              ]
            }
          }
        }
      ]
    }
  ]
}
